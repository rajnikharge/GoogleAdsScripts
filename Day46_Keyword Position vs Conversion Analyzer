function main(){

var report = AdsApp.report(
"SELECT Criteria, AveragePosition, Conversions " +
"FROM KEYWORDS_PERFORMANCE_REPORT DURING LAST_30_DAYS");

var rows = report.rows();

var text="";

while(rows.hasNext()){

var row = rows.next();

text+=row['Criteria']+" Pos:"+row['AveragePosition']+" Conv:"+row['Conversions']+"\n";

}

MailApp.sendEmail("nikhargeraj@gmail.com","Keyword Position Report",text);

}
