function main(){

var report = AdsApp.report(
"SELECT Query, Conversions " +
"FROM SEARCH_QUERY_PERFORMANCE_REPORT DURING LAST_30_DAYS");

var rows = report.rows();

var text="";

while(rows.hasNext()){

var row = rows.next();

if(row['Conversions'] > 5){

text+=row['Query']+"\n";

}

}

MailApp.sendEmail("nikhargeraj@gmail.com","Top Converting Queries",text);

}
