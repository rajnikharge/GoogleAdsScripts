function main(){

var report = AdsApp.report(
"SELECT Query, Clicks, Conversions " +
"FROM SEARCH_QUERY_PERFORMANCE_REPORT DURING LAST_30_DAYS");

var rows = report.rows();

var result="";

while(rows.hasNext()){

var row = rows.next();

var words=row['Query'].split(" ").length;

result+=row['Query']+" Words:"+words+" Conv:"+row['Conversions']+"\n";

}

MailApp.sendEmail("nikhargeraj@gmail.com","Search Query Length Report",result);

}
