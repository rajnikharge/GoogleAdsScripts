function main(){

var report = AdsApp.report(
"SELECT Query, KeywordTextMatchingQuery FROM SEARCH_QUERY_PERFORMANCE_REPORT DURING LAST_7_DAYS"
);

var map = {};

var rows = report.rows();

while(rows.hasNext()){

var row = rows.next();

var query = row["Query"];

var keyword = row["KeywordTextMatchingQuery"];

if(!map[query]){

map[query] = [];

}

map[query].push(keyword);

}

for(var q in map){

if(map[q].length > 1){

Logger.log("Cannibalization Query: "+q);

}

}

}
